# =============================================================================
# Shikkhabhumi API — Docker / VPS environment
# Copy: cp .env.docker.example .env
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL=https://api.shikkhabhumi.com
FRONTEND_URL=https://shikkhabhumi.com

# Extra allowed browser origins (comma-separated). Vercel preview example:
# CORS_EXTRA_ORIGINS=https://shikkhabhumi.vercel.app,https://your-project.vercel.app
# Institute subdomains (https://*.shikkhabhumi.com) are allowed by default in cors.js.
CORS_EXTRA_ORIGINS=

RUN_WORKER=0

# Docker nginx host port
HTTP_PORT=8080

# --- PostgreSQL (Supabase pooler example) ---
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true
DB_POOL_MAX=30
DB_POOL_MIN=2

# --- Auth ---
JWT_SECRET=change_me_long_random_string

# --- Video encryption keys (persisted in Docker volume app_keys) ---
KEYS_ROOT_DIR=./keys

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=videos

# --- Live streaming ---
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
HM_APP_ACCESS_KEY=
HM_APP_SECRET=
HM_TEMPLATE_ID=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Redis (set automatically in docker-compose; override if external) ---
REDIS_URL=redis://redis:6379

# --- Rate limiting & write batching ---
RATE_LIMIT_ENABLED=true
ANALYTICS_BATCH_MS=30000
PROGRESS_BATCH_MS=15000
LIVE_HEARTBEAT_BATCH_MS=15000

# --- Optional ---
# SERVER_TIMEOUT_MS=900000
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_ANALYTICS_MAX=120

# --- Multi-device login limit & abuse detection ---
# MAX_CONCURRENT_DEVICES=2
# DEVICE_ABUSE_WINDOW_DAYS=7
# DEVICE_ABUSE_DISTINCT_THRESHOLD=4
# PENDING_SESSION_TOKEN_TTL_SECONDS=300
